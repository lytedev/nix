-    loadFromModule(QStringLiteral("org.kde.kwin/tileseditor"), QStringLiteral("Main"));
+    // Pre-load the QML component asynchronously so it is ready by the time
+    // the user first triggers the shortcut.  Without this, the synchronous
+    // load in startInternal() blocks the main thread for hundreds of
+    // milliseconds, during which key-release events are not processed and
+    // the OS key-repeat timer can fire a spurious second toggle.
+    auto delegate = new QQmlComponent(effects->qmlEngine(), this);
+    connect(delegate, &QQmlComponent::statusChanged, this, [delegate]() {
+        if (delegate->isError()) {
+            qWarning() << "Failed to load tile editor:" << delegate->errorString();
+        }
+    });
+    delegate->loadFromModule(QStringLiteral("org.kde.kwin/tileseditor"), QStringLiteral("Main"), QQmlComponent::Asynchronous);
+    setDelegate(delegate);
 }
 
