#!/usr/bin/env bash
set -euo pipefail

# pr-review-comments: Fetch and display PR review comments with context
# Usage: pr-review-comments <pr-number>

FORGEJO_URL="${FORGEJO_URL:-https://git.lyte.dev}"
FORGEJO_API="${FORGEJO_API:-$FORGEJO_URL/api/v1}"
FORGEJO_TOKEN="${FORGEJO_TOKEN:-}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Check for PR number argument
if [[ $# -eq 0 ]]; then
  echo "Usage: pr-review-comments <pr-number>"
  echo ""
  echo "Example:"
  echo "  pr-review-comments 177"
  exit 1
fi

PR_NUMBER="$1"

# Check for required tools
for tool in curl jq; do
  if ! command -v "$tool" &> /dev/null; then
    echo -e "${RED}Error: $tool is required but not installed${NC}"
    exit 1
  fi
done

# Check for Forgejo token
if [[ -z "$FORGEJO_TOKEN" ]]; then
  echo -e "${RED}Error: FORGEJO_TOKEN environment variable is not set${NC}"
  echo "Please set your Forgejo API token:"
  echo "  export FORGEJO_TOKEN='your-token-here'"
  exit 1
fi

# Extract owner and repo from git remote
GIT_REMOTE=$(git remote get-url origin 2>/dev/null || echo "")
if [[ -z "$GIT_REMOTE" ]]; then
  echo -e "${RED}Error: No git remote 'origin' found${NC}"
  exit 1
fi

# Parse forgejo@git.lyte.dev:owner/repo.git or https://git.lyte.dev/owner/repo.git
if [[ "$GIT_REMOTE" =~ @.*:(.*)/(.*).git ]] || [[ "$GIT_REMOTE" =~ /.*/(.*)/(.*).git ]]; then
  REPO_OWNER="${BASH_REMATCH[1]}"
  REPO_NAME="${BASH_REMATCH[2]}"
else
  echo -e "${RED}Error: Could not parse git remote: $GIT_REMOTE${NC}"
  exit 1
fi

echo -e "${BLUE}Fetching review comments for PR #$PR_NUMBER...${NC}"
echo ""

# Get all reviews
REVIEWS=$(curl -s -H "Authorization: token $FORGEJO_TOKEN" \
  "$FORGEJO_API/repos/$REPO_OWNER/$REPO_NAME/pulls/$PR_NUMBER/reviews")

if [[ $(echo "$REVIEWS" | jq 'length') -eq 0 ]]; then
  echo -e "${YELLOW}No reviews found for this PR${NC}"
  exit 0
fi

# Process each review
echo "$REVIEWS" | jq -c '.[]' | while read -r review; do
  REVIEW_ID=$(echo "$review" | jq -r '.id')
  REVIEW_STATE=$(echo "$review" | jq -r '.state')
  REVIEW_BODY=$(echo "$review" | jq -r '.body // ""')
  REVIEWER=$(echo "$review" | jq -r '.user.login')
  REVIEW_DATE=$(echo "$review" | jq -r '.submitted_at')

  # Color based on review state
  case "$REVIEW_STATE" in
    APPROVED)
      STATE_COLOR="$GREEN"
      STATE_ICON="✓"
      ;;
    REQUEST_CHANGES|CHANGES_REQUESTED)
      STATE_COLOR="$RED"
      STATE_ICON="✗"
      ;;
    COMMENT)
      STATE_COLOR="$YELLOW"
      STATE_ICON="💬"
      ;;
    *)
      STATE_COLOR="$NC"
      STATE_ICON="○"
      ;;
  esac

  echo -e "${BOLD}Review by $REVIEWER${NC} ${STATE_COLOR}[$STATE_ICON $REVIEW_STATE]${NC}"
  echo -e "${CYAN}Date: $REVIEW_DATE${NC}"

  if [[ -n "$REVIEW_BODY" ]]; then
    echo ""
    echo -e "${BOLD}Review comment:${NC}"
    echo "$REVIEW_BODY"
  fi

  # Get inline comments for this review
  COMMENTS=$(curl -s -H "Authorization: token $FORGEJO_TOKEN" \
    "$FORGEJO_API/repos/$REPO_OWNER/$REPO_NAME/pulls/$PR_NUMBER/reviews/$REVIEW_ID/comments")

  COMMENT_COUNT=$(echo "$COMMENTS" | jq 'length')

  if [[ $COMMENT_COUNT -gt 0 ]]; then
    echo ""
    echo -e "${BOLD}Inline comments ($COMMENT_COUNT):${NC}"
    echo ""

    echo "$COMMENTS" | jq -c '.[]' | while read -r comment; do
      FILE=$(echo "$comment" | jq -r '.path')
      LINE=$(echo "$comment" | jq -r '.position // .line // "?"')
      BODY=$(echo "$comment" | jq -r '.body')
      DIFF_HUNK=$(echo "$comment" | jq -r '.diff_hunk // ""')

      echo -e "${CYAN}  📁 $FILE:$LINE${NC}"

      if [[ -n "$DIFF_HUNK" ]]; then
        echo ""
        echo -e "${BOLD}  Context:${NC}"
        echo "$DIFF_HUNK" | sed 's/^/    /'
        echo ""
      fi

      echo -e "${BOLD}  Comment:${NC}"
      echo "$BODY" | sed 's/^/    /'
      echo ""
      echo "  ---"
      echo ""
    done
  fi

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
done

echo -e "${BLUE}View full PR: $FORGEJO_URL/$REPO_OWNER/$REPO_NAME/pulls/$PR_NUMBER${NC}"
