#!/usr/bin/env nix-shell
#!nix-shell -i bash -p kubectl openssh
# Merge a remote k3s kubeconfig into local ~/.kube/config
# Usage: k3s-kubeconfig-merge <hostname> [context-name]

set -euo pipefail

# NOTE: This grants cluster-admin access to whoever runs it.

HOST="${1:-beefcake}"
CONTEXT_NAME="${2:-$HOST}"
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

echo "Fetching kubeconfig from $HOST..."
echo "You may need to enter your sudo password on $HOST."
echo ""

# Create temp file securely on remote, then scp it (avoids TTY issues with sudo + redirect)
REMOTE_TMP=$(ssh "$HOST" "mktemp /tmp/k3s-config-XXXXXX")
ssh -t "$HOST" "sudo cp /etc/rancher/k3s/k3s.yaml $REMOTE_TMP && sudo chown \$USER $REMOTE_TMP"
scp "$HOST:$REMOTE_TMP" "$TMPDIR/remote.yaml"
ssh "$HOST" "rm -f $REMOTE_TMP" || true

# Strip carriage returns
tr -d '\r' < "$TMPDIR/remote.yaml" > "$TMPDIR/clean.yaml"

# Extract and decode certs to temp files
grep certificate-authority-data "$TMPDIR/clean.yaml" | awk '{print $2}' | base64 -d > "$TMPDIR/ca.crt"
grep client-certificate-data "$TMPDIR/clean.yaml" | awk '{print $2}' | base64 -d > "$TMPDIR/client.crt"
grep client-key-data "$TMPDIR/clean.yaml" | awk '{print $2}' | base64 -d > "$TMPDIR/client.key"

echo "Adding cluster '$CONTEXT_NAME'..."
kubectl config set-cluster "$CONTEXT_NAME" \
  --server="https://${HOST}:6443" \
  --certificate-authority="$TMPDIR/ca.crt" \
  --embed-certs=true

echo "Adding credentials '$CONTEXT_NAME'..."
kubectl config set-credentials "$CONTEXT_NAME" \
  --client-certificate="$TMPDIR/client.crt" \
  --client-key="$TMPDIR/client.key" \
  --embed-certs=true

echo "Adding context '$CONTEXT_NAME'..."
kubectl config set-context "$CONTEXT_NAME" \
  --cluster="$CONTEXT_NAME" \
  --user="$CONTEXT_NAME"

echo ""
echo "Done! Available contexts:"
kubectl config get-contexts

echo ""
echo "Switch with: kubectl config use-context $CONTEXT_NAME"
