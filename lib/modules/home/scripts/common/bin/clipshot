#!/usr/bin/env bash

set -e

umask 077
d="$(date +"%Y-%m-%d_%H-%M-%S")"
fn="$SCROTS_PATH/clipshot_$d.png"
mkdir -p "$SCROTS_PATH"

dim="$(slurp -d -b \#00000066 -c \#ffffffff)" || exit 1

grim -g "$dim" - | wl-copy -t image/png
wl-paste -n > "$fn"

notify-send -a clipshot -i "$fn" "Screenshot copied" "$fn" || true

echo "$fn"
