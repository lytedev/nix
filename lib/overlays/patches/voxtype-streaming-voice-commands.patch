+            if n.is_empty() || hay.len() < n.len() {
+                continue;
+            }
+            for i in 0..=hay.len() - n.len() {
+                if !hay[i..i + n.len()].eq_ignore_ascii_case(n) {
+                    continue;
+                }
+                let before_ok = i == 0 || hay[i - 1].is_ascii_whitespace();
+                if !before_ok {
