+/// PATCHED (lyte.dev): default voice-command map. Overridden by
+/// `$XDG_CONFIG_HOME/voxtype/stream-commands` when present (one
+/// `phrase = Keysym` per line, `#` comments; keysyms are wtype/XKB names).
+const DEFAULT_STREAM_COMMANDS: &[(&str, &str)] = &[
+    ("press page up", "Page_Up"),
+    ("press page down", "Page_Down"),
+    ("press enter", "Return"),
+    ("press return", "Return"),
+    ("press tab", "Tab"),
+    ("press escape", "Escape"),
+    ("press backspace", "BackSpace"),
+    ("press delete", "Delete"),
+    ("press space", "space"),
+    ("press up", "Up"),
+    ("press down", "Down"),
+    ("press left", "Left"),
+    ("press right", "Right"),
+    ("press home", "Home"),
+    ("press end", "End"),
+];
+
+/// PATCHED (lyte.dev): load the voice-command map. Missing or empty file
+/// means the built-in defaults; a present file replaces them entirely.
+fn load_stream_commands() -> Vec<(String, String)> {
+    let path = std::env::var_os("XDG_CONFIG_HOME")
+        .map(std::path::PathBuf::from)
+        .or_else(|| std::env::var_os("HOME").map(|h| std::path::PathBuf::from(h).join(".config")))
+        .map(|d| d.join("voxtype/stream-commands"));
+    if let Some(path) = path {
+        if let Ok(contents) = std::fs::read_to_string(&path) {
+            let mut out = Vec::new();
+            for line in contents.lines() {
+                let line = line.trim();
+                if line.is_empty() || line.starts_with('#') {
+                    continue;
+                }
+                if let Some((phrase, key)) = line.split_once('=') {
+                    let phrase = phrase.trim().to_ascii_lowercase();
+                    let key = key.trim().to_string();
+                    if !phrase.is_empty() && !key.is_empty() {
+                        out.push((phrase, key));
+                    }
+                }
+            }
+            if !out.is_empty() {
+                // Longest phrases first so "press page up" wins over any
+                // shorter phrase sharing a prefix.
+                out.sort_by_key(|(p, _)| std::cmp::Reverse(p.len()));
+                return out;
+            }
+        }
+    }
+    DEFAULT_STREAM_COMMANDS
+        .iter()
+        .map(|(p, k)| (p.to_string(), k.to_string()))
+        .collect()
+}
