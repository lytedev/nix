+/// PATCHED (lyte.dev): press a single key by XKB keysym name. Mirrors the
+/// emit_backspaces driver order below, minus ydotool (which needs raw
+/// keycodes rather than keysym names).
+async fn emit_key(keysym: &str) -> bool {
+    let mut cmd = Command::new("wtype");
+    cmd.arg("-k").arg(keysym);
+    cmd.stdout(Stdio::null()).stderr(Stdio::null());
+    if matches!(cmd.status().await, Ok(s) if s.success()) {
+        return true;
+    }
+    // dotool speaks lowercase key names ("enter", "tab", ...); map the
+    // common keysyms. Anything unmapped just fails and logs upstream.
+    let dotool_key = match keysym {
+        "Return" => "enter",
+        "Tab" => "tab",
+        "Escape" => "esc",
+        "BackSpace" => "backspace",
+        "Delete" => "delete",
+        "space" => "space",
+        "Up" => "up",
+        "Down" => "down",
+        "Left" => "left",
+        "Right" => "right",
+        "Page_Up" => "pageup",
+        "Page_Down" => "pagedown",
+        "Home" => "home",
+        "End" => "end",
+        _ => return false,
+    };
+    use tokio::io::AsyncWriteExt;
+    let (binary, env_pipe) = match crate::output::dotool::DotoolOutput::live_daemon_pipe_path() {
+        Some(p) => ("dotoolc", Some(p)),
+        None => ("dotool", None),
+    };
+    let mut cmd = Command::new(binary);
+    if let Some(p) = env_pipe {
+        cmd.env("DOTOOL_PIPE", p);
+    }
+    cmd.stdin(Stdio::piped())
+        .stdout(Stdio::null())
+        .stderr(Stdio::null());
+    let Ok(mut child) = cmd.spawn() else {
+        return false;
+    };
+    if let Some(mut stdin) = child.stdin.take() {
+        let line = format!("key {}\n", dotool_key);
+        if stdin.write_all(line.as_bytes()).await.is_err() {
+            return false;
+        }
+    }
+    matches!(child.wait().await, Ok(s) if s.success())
+}
