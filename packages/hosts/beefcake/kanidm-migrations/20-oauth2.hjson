    {
      "state": "present",
      "id": "c402a50d-1d8a-45b2-a5b5-e10fb5b125f2",
      "name": "git.lyte.dev",
      "displayname": "git.lyte.dev",
      "oauth2_rs_origin_landing": "https://git.lyte.dev/",
      "oauth2_rs_origin": "https://git.lyte.dev/user/oauth2/idm.h.lyte.dev/callback",
      "oauth2_strict_redirect_uri": true,
