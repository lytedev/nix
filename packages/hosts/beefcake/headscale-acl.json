  "groups": {
    "group:admin": ["daniel@idm.h.lyte.dev"],
    "group:servers": ["server@localhost"],
    "group:family": [],
    "group:friends": []
  },

  "tagOwners": {
    "tag:server": ["group:admin", "server@localhost"],
    "tag:admindevice": ["group:admin"],
    "tag:exitnode": ["group:admin"],
    "tag:backuptarget": ["group:admin"],
    "tag:backupuser": ["group:admin"]
  },

  "acls": [
    {
      "action": "accept",
      "src": ["group:admin", "tag:admindevice"],
      "dst": ["*:*"]
    },
    {
      "action": "accept",
      "src": ["tag:server", "group:servers", "beefcake", "router", "steamdeck", "steamdeckoled", "rascal", "dragon", "flab", "babyflip", "sanctuary"],
      "dst": ["beefcake:80,443", "router:53"]
    },
    {
      "action": "accept",
      "src": ["beefcake"],
      "dst": ["dragon:5000", "rascal:22"]
    },
    {
      "action": "accept",
      "src": ["tag:exitnode"],
      "dst": ["autogroup:internet:*"]
    },
    {
      "action": "accept",
      "src": ["*"],
      "dst": ["router:53"]
    },
    {
      "action": "accept",
      "src": ["*"],
      "dst": ["beefcake:80,443,445,5551"]
    },
    {
      "action": "accept",
      "src": ["tag:backupuser"],
      "dst": ["tag:backuptarget:*"]
    },
    {
      "action": "accept",
      "src": ["group:family"],
      "dst": ["beefcake:80,443"]
    },
    {
      "action": "accept",
      "src": ["group:friends"],
      "dst": ["beefcake:26968,26974,26989,24454"]
    }
  ],

  "ssh": [
    {
      "action": "accept",
      "src": ["group:admin", "tag:admindevice"],
      "dst": ["tag:server"],
      "users": ["root", "autogroup:nonroot"]
    },
    {
      "action": "accept",
      "src": ["group:admin", "tag:admindevice"],
      "dst": ["beefcake", "router", "steamdeck", "steamdeckoled", "rascal", "dragon", "flab", "babyflip", "sanctuary"],
      "users": ["root", "autogroup:nonroot"]
    },
    {
      "action": "accept",
      "src": ["tag:backupuser"],
      "dst": ["tag:backuptarget"],
      "users": ["autogroup:nonroot"]
    }
  ]
}
